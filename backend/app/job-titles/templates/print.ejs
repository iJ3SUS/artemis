<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= jt.name %></title>
    <style>
        * { margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Arial, Helvetica, sans-serif; color: #4a4a4a; font-size: 13px; background: #ffffff; }

        .container { width: 100%; }

        .header-table { width: 100%; margin-bottom: 16px; border-collapse: collapse; }
        .header-table td { vertical-align: middle; border: none; }
        .header-logo { width: 96px; padding-right: 14px; }
        .logo-box { width: 96px; height: 96px; background: #ffffff; text-align: center; overflow: hidden; }
        .logo-box img { max-width: 76px; max-height: 76px; vertical-align: middle; }
        .logo-helper { display: inline-block; height: 100%; vertical-align: middle; }
        .logo-placeholder { font-size: 9px; color: #aaaaaa; text-transform: uppercase; font-weight: 600; }
        .header-info { background: #f5f5f5; padding: 12px 14px; }
        .header-info .company { font-size: 11px; color: #999999; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 2px; }
        .header-info h1 { font-size: 24px; font-weight: 700; color: #3a3a3a; letter-spacing: -0.5px; margin: 0; }
        .header-info .dep { font-size: 13px; color: #777777; margin-top: 3px; }
        .header-meta { text-align: right; }
        .header-meta .tag { font-size: 10px; color: #999999; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px; font-weight: 600; }
        .header-meta .badge { display: inline-block; padding: 4px 20px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; }
        .badge-active { color: #5a8a5a; background: #edf5ed; border: 1px solid #c0dcc0; }
        .badge-inactive { color: #9a7a7a; background: #faf0f0; border: 1px solid #e0c8c8; }
        .header-meta .date { font-size: 11px; color: #aaaaaa; margin-top: 10px; }

        .section { margin-bottom: 12px; border: 1px solid #e0e0e0; }
        .section-title { font-size: 11px; font-weight: 700; color: #555555; text-transform: uppercase; letter-spacing: 1.5px; background: #f0f0f0; padding: 8px 16px; text-align: center; border-bottom: 1px solid #e0e0e0; }
        .section-text { font-size: 12px; color: #4a4a4a; line-height: 1.6; padding: 12px 14px; min-height: 90px; }

        .info-table { width: 100%; border-collapse: collapse; }
        .info-table td { padding: 6px 12px; font-size: 12px; vertical-align: top; border-bottom: 1px solid #f0f0f0; }
        .info-table tr:last-child td { border-bottom: none; }
        .info-table .lbl { width: 120px; color: #888888; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.3px; background: #fafafa; }
        .info-table .val { color: #3a3a3a; }

        .declaration { font-size: 12px; color: #3a3a3a; line-height: 1.8; padding: 14px 16px; text-align: justify; }
        .declaration strong { color: #2a2a2a; }

        .empty-text { color: #bbbbbb; font-style: italic; }

        .signatures { margin-top: 28px; border: 1px solid #e0e0e0; }
        .sig-table { width: 100%; border-collapse: collapse; }
        .sig-table td { width: 50%; text-align: center; vertical-align: top; padding: 20px 16px 12px; }
        .sig-table td:first-child { border-right: 1px solid #e0e0e0; }
        .sig-label { font-size: 9px; color: #aaaaaa; text-transform: uppercase; letter-spacing: 1.2px; margin-bottom: 50px; font-weight: 600; }
        .sig-line { border-bottom: 1px solid #aaaaaa; width: 220px; margin: 0 auto 6px; }
        .sig-name { font-size: 13px; font-weight: 600; color: #3a3a3a; margin-top: 40px; }
        .sig-id { font-size: 10px; color: #888888; margin-top: 2px; }
        .sig-role { font-size: 10px; color: #999999; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }
    </style>
</head>
<body>
    <div class="container">

        <table class="header-table" cellpadding="0" cellspacing="0">
            <tr>
                <td class="header-logo">
                    <div class="logo-box">
                        <% if (company && company.logo) { %>
                            <span class="logo-helper"></span><img src="<%= company.logo %>" alt="Logo" style="max-width:64px;max-height:64px;vertical-align:middle;" />
                        <% } else { %>
                            <span class="logo-helper"></span><span class="logo-placeholder">Logo</span>
                        <% } %>
                    </div>
                </td>
                <td class="header-info">
                    <table cellpadding="0" cellspacing="0" style="width:100%;">
                        <tr>
                            <td style="padding-right:14px;vertical-align:top;">
                                <% if (company && company.name) { %><div class="company"><%= company.name %></div><% } %>
                                <h1><%= jt.name %></h1>
                                <div class="dep"><% if (jt.dependency) { %>ÁREA: <%= jt.dependency %><% } %></div>
                            </td>
                            <td class="header-meta" style="vertical-align:top;">
                                <div class="tag">Ficha del cargo</div>
                                <span class="badge <%= jt.active ? 'badge-active' : 'badge-inactive' %>"><%= jt.active ? 'Activo' : 'Inactivo' %></span>
                                <div class="date"><%= generatedAt %></div>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <% if (emp) { %>
        <div class="section">
            <div class="section-title">Datos del empleado</div>
            <table class="info-table" cellpadding="0" cellspacing="0">
                <tr>
                    <td class="lbl">Nombre completo</td>
                    <td class="val" colspan="3"><%= emp.display_name || '-' %></td>
                </tr>
                <tr>
                    <td class="lbl">Identificación</td>
                    <td class="val"><%= emp.identification || '-' %></td>
                    <td class="lbl">Correo electrónico</td>
                    <td class="val"><%= emp.email || '-' %></td>
                </tr>
                <tr>
                    <td class="lbl">Teléfono</td>
                    <td class="val"><%= empPhone || '-' %></td>
                    <td class="lbl">Fecha de ingreso</td>
                    <td class="val"><%= fmtDate(emp.entry_date) %></td>
                </tr>
                <tr>
                    <td class="lbl">Tipo de contrato</td>
                    <td class="val"><%= contractLabels[emp.contract_type] || '-' %></td>
                    <td class="lbl">Nivel educativo</td>
                    <td class="val"><%= educationLabels[emp.education_level] || '-' %></td>
                </tr>
            </table>
        </div>
        <% } %>

        <div class="section">
            <div class="section-title">Información del cargo</div>
            <table class="info-table" cellpadding="0" cellspacing="0">
                <tr>
                    <td class="lbl">Nombre</td>
                    <td class="val"><%= jt.name || '-' %></td>
                    <td class="lbl">Área</td>
                    <td class="val"><%= jt.dependency || '-' %></td>
                </tr>
                <tr>
                    <td class="lbl" style="padding-top:6px;">Descripción</td>
                    <td class="val" colspan="3" style="line-height:1.6; word-wrap:break-word; overflow-wrap:break-word;"><%= jt.description || 'Sin descripción' %></td>
                </tr>
            </table>
        </div>

        <div class="section">
            <div class="section-title">Funciones del cargo</div>
            <div class="section-text">
                <%- (jt.functions && jt.functions.length) ? jt.functions.join('; ') : '<span class="empty-text">No registradas</span>' %>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Requisitos</div>
            <div class="section-text">
                <%- (jt.requirements && jt.requirements.length) ? jt.requirements.join('; ') : '<span class="empty-text">No registrados</span>' %>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Riesgos</div>
            <div class="section-text">
                <%- (jt.risks && jt.risks.length) ? jt.risks.join('; ') : '<span class="empty-text">No registrados</span>' %>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Declaración de recepción</div>
            <div class="declaration">
                Yo, <strong><%= (emp && emp.display_name) || '_________________________________' %></strong>, identificado con C.C. No. <strong><%= (emp && emp.identification) || '__________________________' %></strong>, doy fe de que recibí y comprendí completamente la descripción del cargo a desempeñar y me comprometo con la empresa a cumplir con las funciones, responsabilidades y autoridades propias del cargo y las específicas al Sistema de Gestión de Seguridad y Salud en el Trabajo definidas en este documento.
            </div>
        </div>

        <div class="signatures">
            <div class="section-title">Firmas</div>
            <table class="sig-table" cellpadding="0" cellspacing="0">
                <tr>
                    <td>
                        <div class="sig-label">Firma del empleado</div>
                        <div class="sig-line"></div>
                        <div class="sig-name"><%= (emp && emp.display_name) || '_______________________' %></div>
                        <% if (emp && emp.identification) { %><div class="sig-id">C.C. <%= emp.identification %></div><% } %>
                        <div class="sig-role">Empleado</div>
                    </td>
                    <td>
                        <div class="sig-label">Firma del gerente</div>
                        <div class="sig-line"></div>
                        <div class="sig-name">_______________________</div>
                        <div class="sig-role">Gerente / Jefe inmediato</div>
                    </td>
                </tr>
            </table>
        </div>

    </div>
</body>
</html>
